# Database
DATABASE_URL=mysql://statman:statman_dev_password@localhost:3306/statman_dev

# Server
PORT=3001
SESSION_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:3001

# Image storage
# Localhost stores under IMAGE_STORAGE_DIR. Railway can set RAILWAY_VOLUME_MOUNT_PATH
# for fallback volume storage. Set IMAGE_STORAGE_DRIVER=r2 plus the R2 values to
# prefer Cloudflare R2 and fall back to the volume/local path if upload fails.
IMAGE_STORAGE_DIR=uploads/images
IMAGE_UPLOAD_MAX_BYTES=5242880
IMAGE_STORAGE_DRIVER=local
RAILWAY_VOLUME_MOUNT_PATH=
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Web (later — Expo/PWA client)
EXPO_PUBLIC_API_URL=http://localhost:3001
